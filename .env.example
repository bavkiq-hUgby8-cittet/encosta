# ═══════════════════════════════════════════════════════
# Touch? (Encosta) -- Variaveis de Ambiente
# Copie para .env e preencha com seus valores
# Em producao: configurar no painel do Render
# NUNCA commitar o .env real -- so este .example
# ═══════════════════════════════════════════════════════

# ── App ──
PORT=3000
APP_URL=https://touch-irl.com
ADMIN_SECRET=
ALLOWED_ORIGINS=https://touch-irl.com,https://www.touch-irl.com

# ── Firebase ──
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_DATABASE_URL=https://encosta-f32e7-default-rtdb.firebaseio.com
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── MercadoPago (BR) ──
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_APP_ID=
MP_CLIENT_SECRET=
MP_REDIRECT_URI=https://touch-irl.com/mp/callback
MP_WEBHOOK_SECRET=
TOUCH_FEE_PERCENT=10

# ── Stripe (US/International) ──
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# ── OpenAI (Voice Agent + Radio TTS) ──
OPENAI_API_KEY=

# ── Anthropic (UltimateDEV cerebro) ──
ANTHROPIC_API_KEY=

# ── Perplexity (Mural AI agents) ──
PPLX_API_KEY=

# ── Groq (alternativo, nao obrigatorio) ──
GROQ_API_KEY=

# ── GitHub (DEV agent auto-commit) ──
GITHUB_TOKEN=
GITHUB_REPO=

# ── Email (opcional -- magic links, verificacao) ──
# Opcao 1: SMTP generico
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Opcao 2: Gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=
