# ═══════════════════════════════════════════════════════
# Touch? (Encosta) -- Variaveis de Ambiente
# Copie para .env e preencha com seus valores
# Em producao: configurar no painel do Render
# NUNCA commitar o .env real -- so este .example
# ═══════════════════════════════════════════════════════

# ── App ──
PORT=3000
APP_URL=https://touch-irl.com
ADMIN_SECRET=
ALLOWED_ORIGINS=https://touch-irl.com,https://www.touch-irl.com

# ── Firebase ──
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_DATABASE_URL=https://encosta-f32e7-default-rtdb.firebaseio.com
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── MercadoPago (BR) ──
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_APP_ID=
MP_CLIENT_SECRET=
MP_REDIRECT_URI=https://touch-irl.com/mp/callback
MP_WEBHOOK_SECRET=
TOUCH_FEE_PERCENT=10

# ── Stripe (US/International) ──
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# ── OpenAI (Voice Agent + Radio TTS) ──
OPENAI_API_KEY=

# ── Anthropic (UltimateDEV cerebro) ──
ANTHROPIC_API_KEY=

# ── Perplexity (Mural AI agents) ──
PPLX_API_KEY=

# ── Groq (alternativo, nao obrigatorio) ──
GROQ_API_KEY=

# ── GitHub (DEV agent auto-commit) ──
GITHUB_TOKEN=
GITHUB_REPO=

# ── Email (opcional -- magic links, verificacao, recuperar senha) ──
# Escolha UMA das opcoes abaixo:

# Opcao 1: SMTP generico (SendGrid, Mailgun, etc)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Touch?" <noreply@touch-irl.com>

# Opcao 2: Gmail (precisa App Password em myaccount.google.com/apppasswords)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Opcao 3: Resend (resend.com -- gratis ate 100 emails/dia, recomendado)
# Crie conta em resend.com, gere API Key, adicione dominio touch-irl.com
RESEND_API_KEY=

# ── YouTube Data API (Karaoke module -- busca de musicas) ──
# Crie em console.cloud.google.com > APIs > YouTube Data API v3
YOUTUBE_API_KEY=
